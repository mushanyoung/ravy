#!/bin/bash
# Attach to a local or remote cloudtop session.

usage() {
  cat <<'EOF'
Usage: cloudtop [--ssh|--mosh] [--zellij] [--] [host] [transport args...]

Without a host, attaches to a local zellij session.
With a host, defaults to ssh transport and zellij on the remote host.

Options:
  --ssh       Use ssh transport (default)
  --mosh      Use mosh transport
  --zellij    Attach to a zellij session (default)
  -h, --help  Show this help
EOF
}

print_command() {
  printf '+'
  for arg in "$@"; do
    printf ' %q' "$arg"
  done
  printf '\n'
}

shell_quote() {
  local quoted=${1//\'/\'\\\'\'}
  printf "'%s'" "$quoted"
}

find_zellij() {
  local candidate
  local install_dir

  candidate=$(command -v zellij 2>/dev/null || true)
  if [ -n "$candidate" ] && [ -x "$candidate" ]; then
    printf '%s\n' "$candidate"
    return 0
  fi

  if command -v mise >/dev/null 2>&1; then
    candidate=$(mise which zellij 2>/dev/null || true)
    if [ -n "$candidate" ] && [ -x "$candidate" ]; then
      printf '%s\n' "$candidate"
      return 0
    fi

    install_dir=$(mise where zellij 2>/dev/null || true)
    for candidate in "$install_dir/zellij" "$install_dir/bin/zellij"; do
      [ -n "$install_dir" ] || continue
      [ -x "$candidate" ] || continue
      printf '%s\n' "$candidate"
      return 0
    done
  fi

  for candidate in \
    /opt/homebrew/bin/zellij \
    /home/linuxbrew/.linuxbrew/bin/zellij \
    "$HOME/.linuxbrew/bin/zellij" \
    "$HOME/.brew/bin/zellij" \
    /usr/local/bin/zellij
  do
    [ -n "$candidate" ] || continue
    [ -x "$candidate" ] || continue
    printf '%s\n' "$candidate"
    return 0
  done

  return 1
}

zellij_not_found_message() {
  echo "zellij not found; checked PATH, mise zellij, and common Homebrew prefixes" >&2
  echo "Install it with: mise install zellij" >&2
}

zellij_session_name() {
  local raw_name cleaned_name

  raw_name=${RAVY_ZELLIJ_HOST:-${RAVY_HOST:-}}
  if [ -z "$raw_name" ]; then
    raw_name=$(hostname -s 2>/dev/null || hostname 2>/dev/null || true)
  fi

  cleaned_name=$(printf '%s' "$raw_name" |
    LC_ALL=C tr '[:upper:]' '[:lower:]' |
    LC_ALL=C sed 's/[^a-z0-9_-][^a-z0-9_-]*/-/g; s/^-*//; s/-*$//' |
    cut -c 1-10 |
    LC_ALL=C sed 's/^-*//; s/-*$//')

  printf '%s\n' "${cleaned_name:-cloudtop}"
}

hash_text() {
  local text=$1
  local digest

  if command -v sha256sum >/dev/null 2>&1; then
    digest=$(printf '%s' "$text" | sha256sum | awk '{ print $1 }') || return 1
  elif command -v shasum >/dev/null 2>&1; then
    digest=$(printf '%s' "$text" | shasum -a 256 | awk '{ print $1 }') || return 1
  elif command -v openssl >/dev/null 2>&1; then
    digest=$(printf '%s' "$text" | openssl dgst -sha256 | awk '{ print $NF }') || return 1
  else
    echo "cloudtop needs sha256sum, shasum, or openssl to cache the remote helper" >&2
    return 1
  fi

  printf '%s\n' "$digest" | cut -c 1-5
}

cloudtop_remote_helper_script() {
  cat <<'EOF'
#!/bin/sh

cloudtop_refresh_ssh_auth_sock() {
    stable_sock=${CLOUDTOP_SSH_AUTH_SOCK:-$HOME/.ssh/ssh_auth_sock}

    [ -n "${SSH_AUTH_SOCK:-}" ] || return 0
    [ -S "$SSH_AUTH_SOCK" ] || return 0
    [ "$SSH_AUTH_SOCK" != "$stable_sock" ] || return 0
    [ ! -d "$stable_sock" ] || return 0

    stable_dir=${stable_sock%/*}
    [ "$stable_dir" != "$stable_sock" ] || stable_dir=.
    mkdir -p "$stable_dir" || return 0

    tmp_sock="${stable_sock}.$$"
    rm -f "$tmp_sock"
    if ln -s "$SSH_AUTH_SOCK" "$tmp_sock" 2>/dev/null; then
        mv -f "$tmp_sock" "$stable_sock" 2>/dev/null || rm -f "$tmp_sock"
    fi

    if [ -S "$stable_sock" ]; then
        SSH_AUTH_SOCK=$stable_sock
        export SSH_AUTH_SOCK
    fi
}

zellij_session_name() {
    raw_name=${RAVY_ZELLIJ_HOST:-${RAVY_HOST:-}}
    if [ -z "$raw_name" ]; then
        raw_name=$(hostname -s 2>/dev/null || hostname 2>/dev/null || true)
    fi

    cleaned_name=$(printf '%s' "$raw_name" |
        LC_ALL=C tr '[:upper:]' '[:lower:]' |
        LC_ALL=C sed 's/[^a-z0-9_-][^a-z0-9_-]*/-/g; s/^-*//; s/-*$//' |
        cut -c 1-10 |
        LC_ALL=C sed 's/^-*//; s/-*$//')

    printf '%s\n' "${cleaned_name:-cloudtop}"
}

find_zellij() {
    candidate=$(command -v zellij 2>/dev/null || true)
    if [ -n "$candidate" ] && [ -x "$candidate" ]; then
        printf '%s\n' "$candidate"
        return 0
    fi

    if command -v mise >/dev/null 2>&1; then
        candidate=$(mise which zellij 2>/dev/null || true)
        if [ -n "$candidate" ] && [ -x "$candidate" ]; then
            printf '%s\n' "$candidate"
            return 0
        fi

        install_dir=$(mise where zellij 2>/dev/null || true)
        for candidate in "$install_dir/zellij" "$install_dir/bin/zellij"; do
            [ -n "$install_dir" ] || continue
            [ -x "$candidate" ] || continue
            printf '%s\n' "$candidate"
            return 0
        done
    fi

    for candidate in \
        /opt/homebrew/bin/zellij \
        /home/linuxbrew/.linuxbrew/bin/zellij \
        "$HOME/.linuxbrew/bin/zellij" \
        "$HOME/.brew/bin/zellij" \
        /usr/local/bin/zellij
    do
        [ -n "$candidate" ] || continue
        [ -x "$candidate" ] || continue
        printf '%s\n' "$candidate"
        return 0
    done

    return 1
}

attach_zellij() {
    session_name=$(zellij_session_name)

    candidate=$(find_zellij) || {
        echo "zellij not found; checked PATH, mise zellij, and common Homebrew prefixes" >&2
        echo "Install it with: mise install zellij" >&2
        exit 127
    }
    exec "$candidate" attach --forget --create "$session_name"
    exit 127
}

enable_agent_bridge=${1:-0}

if [ "$enable_agent_bridge" = 1 ]; then
    cloudtop_refresh_ssh_auth_sock
fi

attach_zellij
EOF
}

attach_local() {
  local candidate
  local session_name

  session_name=$(zellij_session_name)
  candidate=$(find_zellij) || {
    zellij_not_found_message
    exit 127
  }
  print_command "$candidate" attach --forget --create "$session_name"
  exec "$candidate" attach --forget --create "$session_name"
  exit 127
}

validate_mosh_helper_args() {
  if [ "${#transport_args[@]}" -ne 1 ] || [[ ${transport_args[0]} == -* ]]; then
    echo "cloudtop --mosh cached helper supports only a single [user@]host argument; use MOSH_SSH_PORT for the SSH port or MOSH_EXEC_CMD for a custom inline command" >&2
    exit 2
  fi
}

build_cached_remote_command() {
  local enable_agent_bridge=$1
  local remote_exec_script
  local remote_install_script

  remote_helper_script=$(cloudtop_remote_helper_script)
  remote_helper_hash=$(hash_text "$remote_helper_script") || exit 1
  remote_helper_enabled=1

  remote_install_script="helper_dir=\$HOME/.cache/cloudtop/$remote_helper_hash; helper_path=\$helper_dir/attach; if [ -x \"\$helper_path\" ]; then exit 0; fi; umask 077; mkdir -p \"\$helper_dir\" || exit 1; tmp_path=\"\$helper_dir/attach.\$\$\"; rm -f \"\$tmp_path\"; cat > \"\$tmp_path\" || exit 1; chmod 700 \"\$tmp_path\" || { rm -f \"\$tmp_path\"; exit 1; }; if [ -x \"\$helper_path\" ]; then rm -f \"\$tmp_path\"; else mv -f \"\$tmp_path\" \"\$helper_path\" || { rm -f \"\$tmp_path\"; exit 1; }; fi"
  remote_helper_install_cmd="/bin/sh -lc $(shell_quote "$remote_install_script")"

  remote_exec_script="exec \"\$HOME/.cache/cloudtop/$remote_helper_hash/attach\" $enable_agent_bridge"
  remote_exec_cmd="/bin/sh -lc $(shell_quote "$remote_exec_script")"
  remote_exec_argv=(/bin/sh -lc "$remote_exec_script")
}

build_remote_command() {
  local script
  local enable_agent_bridge=0

  remote_helper_enabled=0
  remote_helper_script=
  remote_helper_hash=
  remote_helper_install_cmd=

  if [ -n "${CLOUDTOP_EXEC_CMD:-}" ]; then
    script=$CLOUDTOP_EXEC_CMD
  elif [ "$transport" = "ssh" ] && [ -n "${SSH_EXEC_CMD:-}" ]; then
    script=$SSH_EXEC_CMD
  elif [ "$transport" = "mosh" ] && [ -n "${MOSH_EXEC_CMD:-}" ]; then
    script=$MOSH_EXEC_CMD
  else
    if [ "$transport" = "ssh" ]; then
      enable_agent_bridge=1
    fi
    if [ "$transport" = "mosh" ]; then
      validate_mosh_helper_args
    fi
    build_cached_remote_command "$enable_agent_bridge"
    return
  fi

  remote_exec_cmd="/bin/sh -lc $(shell_quote "$script")"
  remote_exec_argv=(/bin/sh -lc "$script")
}

install_remote_helper() {
  local -a command
  local -a install_opts

  [ "${remote_helper_enabled:-0}" = 1 ] || return 0

  install_opts=("${ssh_install_opts[@]}")
  if [ "$transport" = "mosh" ] && [ -n "$mosh_ssh_port" ]; then
    install_opts+=("-p" "$mosh_ssh_port")
  fi

  command=("$ssh_command" "${install_opts[@]}" "${transport_args[@]}" -- "$remote_helper_install_cmd")
  print_command "${command[@]}"
  printf '%s' "$remote_helper_script" | "${command[@]}"
}

run_once() {
  local -a command

  if [ "$transport" = "ssh" ]; then
    command=("$ssh_command" "${ssh_default_opts[@]}" "${transport_args[@]}" -- "$remote_exec_cmd")
  else
    command=("$mosh_command")
    if [ -n "$mosh_ssh_port" ]; then
      command+=("--ssh=ssh -p $mosh_ssh_port")
    fi
    command+=("${mosh_default_opts[@]}" -- "${transport_args[@]}" "${remote_exec_argv[@]}")
  fi

  print_command "${command[@]}"
  "${command[@]}"
}

transport=ssh
transport_args=()

while [ "$#" -gt 0 ]; do
  case "$1" in
    --ssh)
      transport=ssh
      ;;
    --mosh)
      transport=mosh
      ;;
    --zellij)
      ;;
    --tmux)
      echo "cloudtop no longer supports tmux" >&2
      exit 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      transport_args+=("$@")
      break
      ;;
    *)
      transport_args+=("$1")
      ;;
  esac
  shift
done

if [ "${#transport_args[@]}" -eq 0 ]; then
  attach_local
fi

if [ -n "${SSH_CONNECTION:-}" ]; then
  echo "It looks like you're already in a SSH connection: $SSH_CONNECTION" >&2
  exit 1
fi

ssh_command=${SSH_COMMAND:-ssh}
mosh_command=${MOSH_COMMAND:-mosh}
mosh_ssh_port=${MOSH_SSH_PORT:-}
ssh_alive_interval=${SSH_ALIVE_INTERVAL:-10}
reconnect_interval=${RECONNECT_INTERVAL:-10}
ssh_default_opts=("-t" "-S" "none" "-oCompression=yes" "-oCheckHostIP=no" "-oServerAliveInterval=${ssh_alive_interval}")
ssh_install_opts=("-T" "-S" "none" "-oCompression=yes" "-oCheckHostIP=no" "-oServerAliveInterval=${ssh_alive_interval}")
mosh_default_opts=("-a" "-o")

build_remote_command
install_remote_helper || exit $?

while true; do
  run_once
  exit_code=$?
  if [ "$transport" = "ssh" ]; then
    echo "SSH exits with code $exit_code"
  else
    echo "MOSH exits with code $exit_code"
  fi
  case "$exit_code" in
    0|255)
      break
      ;;
  esac
  echo "${transport} connection lost, reconnecting in ${reconnect_interval} seconds..."
  sleep "${reconnect_interval}"
done
