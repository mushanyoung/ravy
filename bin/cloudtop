#!/bin/bash
# Attach to a local or remote cloudtop session.

usage() {
  cat <<'EOF'
Usage: cloudtop [--ssh|--mosh] [--zellij|--tmux] [--] [host] [transport args...]

Without a host, attaches to a local zellij session.
With a host, defaults to ssh transport and zellij on the remote host.

Options:
  --ssh       Use ssh transport (default)
  --mosh      Use mosh transport
  --zellij    Attach to a zellij session (default)
  --tmux      Attach to a tmux session
  -h, --help  Show this help
EOF
}

print_command() {
  printf '+'
  for arg in "$@"; do
    printf ' %q' "$arg"
  done
  printf '\n'
}

shell_quote() {
  local quoted=${1//\'/\'\\\'\'}
  printf "'%s'" "$quoted"
}

find_zellij() {
  local candidate
  local install_dir

  candidate=$(command -v zellij 2>/dev/null || true)
  if [ -n "$candidate" ] && [ -x "$candidate" ]; then
    printf '%s\n' "$candidate"
    return 0
  fi

  if command -v mise >/dev/null 2>&1; then
    candidate=$(mise which zellij 2>/dev/null || true)
    if [ -n "$candidate" ] && [ -x "$candidate" ]; then
      printf '%s\n' "$candidate"
      return 0
    fi

    install_dir=$(mise where zellij 2>/dev/null || true)
    for candidate in "$install_dir/zellij" "$install_dir/bin/zellij"; do
      [ -n "$install_dir" ] || continue
      [ -x "$candidate" ] || continue
      printf '%s\n' "$candidate"
      return 0
    done
  fi

  for candidate in \
    /opt/homebrew/bin/zellij \
    /home/linuxbrew/.linuxbrew/bin/zellij \
    "$HOME/.linuxbrew/bin/zellij" \
    "$HOME/.brew/bin/zellij" \
    /usr/local/bin/zellij
  do
    [ -n "$candidate" ] || continue
    [ -x "$candidate" ] || continue
    printf '%s\n' "$candidate"
    return 0
  done

  return 1
}

zellij_not_found_message() {
  echo "zellij not found; checked PATH, mise zellij, and common Homebrew prefixes" >&2
  echo "Install it with: mise install zellij" >&2
}

zellij_session_name() {
  local raw_name cleaned_name

  raw_name=${RAVY_ZELLIJ_HOST:-${RAVY_HOST:-}}
  if [ -z "$raw_name" ]; then
    raw_name=$(hostname -s 2>/dev/null || hostname 2>/dev/null || true)
  fi

  cleaned_name=$(printf '%s' "$raw_name" |
    LC_ALL=C tr '[:upper:]' '[:lower:]' |
    LC_ALL=C sed 's/[^a-z0-9_-][^a-z0-9_-]*/-/g; s/^-*//; s/-*$//' |
    cut -c 1-10 |
    LC_ALL=C sed 's/^-*//; s/-*$//')

  printf '%s\n' "${cleaned_name:-cloudtop}"
}

remote_ssh_auth_sock_bridge_script() {
  cat <<'EOF'
cloudtop_refresh_ssh_auth_sock() {
    stable_sock=${CLOUDTOP_SSH_AUTH_SOCK:-$HOME/.ssh/ssh_auth_sock}

    [ -n "${SSH_AUTH_SOCK:-}" ] || return 0
    [ -S "$SSH_AUTH_SOCK" ] || return 0
    [ "$SSH_AUTH_SOCK" != "$stable_sock" ] || return 0
    [ ! -d "$stable_sock" ] || return 0

    stable_dir=${stable_sock%/*}
    [ "$stable_dir" != "$stable_sock" ] || stable_dir=.
    mkdir -p "$stable_dir" || return 0

    tmp_sock="${stable_sock}.$$"
    rm -f "$tmp_sock"
    if ln -s "$SSH_AUTH_SOCK" "$tmp_sock" 2>/dev/null; then
        mv -f "$tmp_sock" "$stable_sock" 2>/dev/null || rm -f "$tmp_sock"
    fi

    if [ -S "$stable_sock" ]; then
        SSH_AUTH_SOCK=$stable_sock
        export SSH_AUTH_SOCK
    fi
}

cloudtop_refresh_ssh_auth_sock
EOF
}

remote_attach_script() {
  case "$1" in
    zellij)
      if [ "${2:-0}" = 1 ]; then
        remote_ssh_auth_sock_bridge_script
      fi
      cat <<'EOF'
zellij_session_name() {
    raw_name=${RAVY_ZELLIJ_HOST:-${RAVY_HOST:-}}
    if [ -z "$raw_name" ]; then
        raw_name=$(hostname -s 2>/dev/null || hostname 2>/dev/null || true)
    fi

    cleaned_name=$(printf '%s' "$raw_name" |
        LC_ALL=C tr '[:upper:]' '[:lower:]' |
        LC_ALL=C sed 's/[^a-z0-9_-][^a-z0-9_-]*/-/g; s/^-*//; s/-*$//' |
        cut -c 1-10 |
        LC_ALL=C sed 's/^-*//; s/-*$//')

    printf '%s\n' "${cleaned_name:-cloudtop}"
}

session_name=$(zellij_session_name)

find_zellij() {
    candidate=$(command -v zellij 2>/dev/null || true)
    if [ -n "$candidate" ] && [ -x "$candidate" ]; then
        printf '%s\n' "$candidate"
        return 0
    fi

    if command -v mise >/dev/null 2>&1; then
        candidate=$(mise which zellij 2>/dev/null || true)
        if [ -n "$candidate" ] && [ -x "$candidate" ]; then
            printf '%s\n' "$candidate"
            return 0
        fi

        install_dir=$(mise where zellij 2>/dev/null || true)
        for candidate in "$install_dir/zellij" "$install_dir/bin/zellij"; do
            [ -n "$install_dir" ] || continue
            [ -x "$candidate" ] || continue
            printf '%s\n' "$candidate"
            return 0
        done
    fi

    for candidate in \
        /opt/homebrew/bin/zellij \
        /home/linuxbrew/.linuxbrew/bin/zellij \
        "$HOME/.linuxbrew/bin/zellij" \
        "$HOME/.brew/bin/zellij" \
        /usr/local/bin/zellij
    do
        [ -n "$candidate" ] || continue
        [ -x "$candidate" ] || continue
        printf '%s\n' "$candidate"
        return 0
    done

    return 1
}

candidate=$(find_zellij) || {
    echo "zellij not found; checked PATH, mise zellij, and common Homebrew prefixes" >&2
    echo "Install it with: mise install zellij" >&2
    exit 127
}
exec "$candidate" attach --forget --create "$session_name"
exit 127
EOF
      ;;
    tmux)
      if [ "${2:-0}" = 1 ]; then
        remote_ssh_auth_sock_bridge_script
      fi
      cat <<'EOF'
for candidate in "$(command -v tmux 2>/dev/null)" \
    /opt/homebrew/bin/tmux \
    /home/linuxbrew/.linuxbrew/bin/tmux \
    "$HOME/.linuxbrew/bin/tmux" \
    "$HOME/.brew/bin/tmux" \
    /usr/local/bin/tmux
do
    [ -n "$candidate" ] || continue
    [ -x "$candidate" ] || continue
    exec "$candidate" new-session -A -s tmux
done
echo "tmux not found; checked PATH=$PATH and common Homebrew prefixes" >&2
exit 127
EOF
      ;;
  esac
}

attach_local() {
  local candidate
  local session_name

  case "$remote_program" in
    zellij)
      session_name=$(zellij_session_name)
      candidate=$(find_zellij) || {
        zellij_not_found_message
        exit 127
      }
      print_command "$candidate" attach --forget --create "$session_name"
      exec "$candidate" attach --forget --create "$session_name"
      exit 127
      ;;
    tmux)
      for candidate in "$(command -v tmux 2>/dev/null)" \
          /opt/homebrew/bin/tmux \
          /home/linuxbrew/.linuxbrew/bin/tmux \
          "$HOME/.linuxbrew/bin/tmux" \
          "$HOME/.brew/bin/tmux" \
          /usr/local/bin/tmux
      do
        [ -n "$candidate" ] || continue
        [ -x "$candidate" ] || continue
        print_command "$candidate" new-session -A -s tmux
        exec "$candidate" new-session -A -s tmux
      done
      echo "tmux not found; checked PATH=$PATH and common Homebrew prefixes" >&2
      exit 127
      ;;
  esac
}

build_remote_command() {
  local script
  local enable_agent_bridge=0

  if [ -n "${CLOUDTOP_EXEC_CMD:-}" ]; then
    script=$CLOUDTOP_EXEC_CMD
  elif [ "$transport" = "ssh" ] && [ -n "${SSH_EXEC_CMD:-}" ]; then
    script=$SSH_EXEC_CMD
  elif [ "$transport" = "mosh" ] && [ -n "${MOSH_EXEC_CMD:-}" ]; then
    script=$MOSH_EXEC_CMD
  else
    if [ "$transport" = "ssh" ]; then
      enable_agent_bridge=1
    fi
    script=$(remote_attach_script "$remote_program" "$enable_agent_bridge")
  fi

  remote_exec_cmd="/bin/sh -lc $(shell_quote "$script")"
  remote_exec_argv=(/bin/sh -lc "$script")
}

run_once() {
  local -a command

  if [ "$transport" = "ssh" ]; then
    command=("$ssh_command" "${ssh_default_opts[@]}" "${transport_args[@]}" -- "$remote_exec_cmd")
  else
    command=("$mosh_command")
    if [ -n "$mosh_ssh_port" ]; then
      command+=("--ssh=ssh -p $mosh_ssh_port")
    fi
    command+=("${mosh_default_opts[@]}" -- "${transport_args[@]}" "${remote_exec_argv[@]}")
  fi

  print_command "${command[@]}"
  "${command[@]}"
}

transport=ssh
remote_program=zellij
transport_args=()

while [ "$#" -gt 0 ]; do
  case "$1" in
    --ssh)
      transport=ssh
      ;;
    --mosh)
      transport=mosh
      ;;
    --zellij)
      remote_program=zellij
      ;;
    --tmux)
      remote_program=tmux
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      transport_args+=("$@")
      break
      ;;
    *)
      transport_args+=("$1")
      ;;
  esac
  shift
done

if [ "${#transport_args[@]}" -eq 0 ]; then
  attach_local
fi

if [ -n "${SSH_CONNECTION:-}" ]; then
  echo "It looks like you're already in a SSH connection: $SSH_CONNECTION" >&2
  exit 1
fi

ssh_command=${SSH_COMMAND:-ssh}
mosh_command=${MOSH_COMMAND:-mosh}
mosh_ssh_port=${MOSH_SSH_PORT:-}
ssh_alive_interval=${SSH_ALIVE_INTERVAL:-10}
reconnect_interval=${RECONNECT_INTERVAL:-10}
ssh_default_opts=("-t" "-S" "none" "-oCompression=yes" "-oCheckHostIP=no" "-oServerAliveInterval=${ssh_alive_interval}")
mosh_default_opts=("-a" "-o")

build_remote_command

while true; do
  run_once
  exit_code=$?
  if [ "$transport" = "ssh" ]; then
    echo "SSH exits with code $exit_code"
  else
    echo "MOSH exits with code $exit_code"
  fi
  case "$exit_code" in
    0|255)
      break
      ;;
  esac
  echo "${transport} connection lost, reconnecting in ${reconnect_interval} seconds..."
  sleep "${reconnect_interval}"
done
