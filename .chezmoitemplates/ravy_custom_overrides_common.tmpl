{{- /* Shared custom override loading.
      Expects .shell to be "bash", "zsh", or "fish". */ -}}
{{- $shell := .shell -}}

{{- if eq $shell "fish" }}
# Optional private overlay + managed secret files.
if not set -q RAVY_SKIP_CUSTOM
    set -l private_home "$RAVY_PRIVATE_HOME"

    if test -n "$private_home"; and test -d "$private_home"
        for file in \
            "$private_home/shell/config.fish" \
            "$private_home/profiles/$RAVY_PROFILE/shell/config.fish"
            test -f "$file"
            and source "$file"
        end
    end

    test -f "$HOME/.config/ravy/secrets.fish"
    and source "$HOME/.config/ravy/secrets.fish"
end
{{- else }}
# Optional private overlay + managed secret files.
if [ -z "${RAVY_SKIP_CUSTOM:-}" ]; then
  _ravy_private_home="${RAVY_PRIVATE_HOME:-}"
{{- if eq $shell "bash" }}
  _ravy_shell_suffix="bash"
{{- else }}
  _ravy_shell_suffix="zsh"
{{- end }}

  if [ -n "$_ravy_private_home" ]; then
    for _ravy_file in \
      "$_ravy_private_home/shell/config.sh" \
      "$_ravy_private_home/shell/config.$_ravy_shell_suffix" \
      "$_ravy_private_home/profiles/${RAVY_PROFILE:-}/shell/config.sh" \
      "$_ravy_private_home/profiles/${RAVY_PROFILE:-}/shell/config.$_ravy_shell_suffix"
    do
      [ -f "$_ravy_file" ] || continue
      # shellcheck disable=SC1090
      . "$_ravy_file"
    done
  fi

  if [ -f "$HOME/.config/ravy/secrets.sh" ]; then
    # shellcheck disable=SC1090
    . "$HOME/.config/ravy/secrets.sh"
  fi

  unset _ravy_file _ravy_private_home _ravy_shell_suffix
fi
{{- end }}
