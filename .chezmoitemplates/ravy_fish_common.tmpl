{{- /* Fish common setup (non-interactive safe): RAVY_HOME, PATH, Homebrew env. */ -}}
#
# Resolve RAVY_HOME:
# - Prefer chezmoi source-path when available
# - Fall back to the default source dir used by chezmoi
# - Fall back to legacy ~/.ravy
if command -v chezmoi >/dev/null
    set -l sp (chezmoi source-path 2>/dev/null)
    if test -n "$sp"
        set -gx RAVY_HOME $sp
    end
end
if not set -q RAVY_HOME
    if test -d "$HOME/.local/share/chezmoi"
        set -gx RAVY_HOME "$HOME/.local/share/chezmoi"
    else
        set -gx RAVY_HOME "$HOME/.ravy"
    end
end

if not set -q RAVY_PRIVATE_HOME
    for candidate in "$HOME/.local/share/ravy-private" "$HOME/.ravy-private" "$RAVY_HOME/custom"
        if test -d "$candidate"
            set -gx RAVY_PRIVATE_HOME "$candidate"
            break
        end
    end
end
if set -q RAVY_PRIVATE_HOME
    if not test -d "$RAVY_PRIVATE_HOME"
        set -e RAVY_PRIVATE_HOME
    end
end
if set -q RAVY_PRIVATE_HOME
    set -gx RAVY_CUSTOM "$RAVY_PRIVATE_HOME"
end

if not set -q RAVY_HOST
    set -gx RAVY_HOST (hostname -s 2>/dev/null | string lower)
end
if not set -q RAVY_OS
    set -gx RAVY_OS (uname -s 2>/dev/null | string lower)
end

# PATH operations
function prepend_to_path
    for arg in $argv
        if test -d "$arg"
            if set -l idx (contains -i -- "$arg" $PATH)
                set -e PATH[$idx]
            end
            set -gx PATH "$arg" $PATH
        end
    end
end

function append_to_path
    for arg in $argv
        if test -d "$arg"
            if set -l idx (contains -i -- "$arg" $PATH)
                set -e PATH[$idx]
            end
            set -gx PATH $PATH "$arg"
        end
    end
end

# User scripts
prepend_to_path "$HOME/bin"
prepend_to_path "$HOME/.local/bin"
prepend_to_path "$HOME/.bun/bin"
prepend_to_path "$RAVY_HOME/bin"
if set -q RAVY_PRIVATE_HOME
    append_to_path "$RAVY_PRIVATE_HOME/bin/common"
end

if not set -q RAVY_SKIP_BREW
    set -l brewprefix ''
    if command -q brew
        set brewprefix (brew --prefix 2>/dev/null)
    end
    if test -z "$brewprefix"
        for candidate in /opt/homebrew /usr/local /home/linuxbrew/.linuxbrew "$HOME/.brew" "$HOME/.linuxbrew"
            if test -x "$candidate/bin/brew"
                set brewprefix "$candidate"
                break
            end
        end
    end

    if test -n "$brewprefix"
        set -gx HOMEBREW_PREFIX "$brewprefix"
        set -gx HOMEBREW_CELLAR "$brewprefix/Cellar"
        set -gx HOMEBREW_REPOSITORY "$brewprefix/Homebrew"
        set -gx HOMEBREW_NO_ANALYTICS 1
        set -q MANPATH; or set MANPATH ''
        set -gx MANPATH "$HOMEBREW_PREFIX/share/man" $MANPATH
        set -q INFOPATH; or set INFOPATH ''
        set -gx INFOPATH "$HOMEBREW_PREFIX/share/info" $INFOPATH

        if test -d "$brewprefix/opt/ruby/bin"
            prepend_to_path "$brewprefix/opt/ruby/bin"
        end

        prepend_to_path "$HOMEBREW_PREFIX/bin" "$HOMEBREW_PREFIX/sbin"
    end
end

# mise
if command -v mise &>/dev/null
    mise activate fish | source
end
