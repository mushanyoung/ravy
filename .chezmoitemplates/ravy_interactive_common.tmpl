{{- /* Shared interactive commands across shells.
      Expects .shell to be "bash", "zsh", or "fish". */ -}}
{{- $shell := .shell -}}

{{- if eq $shell "fish" }}
# docker helpers
alias dpri "docker image prune"
alias dprs "docker system prune --all"
alias dli "docker image list"
alias dls "docker system info"
alias dry "docker run --rm -it -v /var/run/docker.sock:/var/run/docker.sock moncho/dry"

alias ravyc ravyprivatecd
alias ravyprivate ravyprivatecd
alias ravys ravysource

# Fish supports "=" aliases but bash/zsh do not.
alias = "command -v"

function __ravy_chezmoi_config_dir
    set -l config_home "$XDG_CONFIG_HOME"
    test -n "$config_home"; or set config_home "$HOME/.config"
    printf '%s\n' "$config_home/chezmoi"
end

function __ravy_chezmoi_seed_config --argument-names config_path
    if test -f "$config_path"
        return 0
    end

    set -l config_dir (__ravy_chezmoi_config_dir)
    for candidate in "$config_dir/chezmoi.toml" "$config_dir/ravy-public.toml"
        if test "$candidate" = "$config_path"
            continue
        end
        if test -f "$candidate"
            mkdir -p (dirname "$config_path")
            command cp "$candidate" "$config_path"
            return 0
        end
    end
end

function __ravy_chezmoi_run
    set -l source_dir "$argv[1]"
    set -l config_path "$argv[2]"
    set -l state_path "$argv[3]"
    set -e argv[1..3]

    if test (count $argv) -gt 0; and test "$argv[1]" = init
        mkdir -p (dirname "$config_path")
        command chezmoi -S "$source_dir" -c "$config_path" --persistent-state "$state_path" init -C "$config_path" $argv[2..-1]
        test -f "$config_path"; or __ravy_chezmoi_seed_config "$config_path"
    else
        __ravy_chezmoi_seed_config "$config_path"
        command chezmoi -S "$source_dir" -c "$config_path" --persistent-state "$state_path" $argv
    end
end

function d
    builtin cd ..
end

function ravy
    builtin cd -- "$RAVY_HOME"
end

function chez
    command chezmoi $argv
end

function ravycustom
    ravyprivatecd
end

function ravyprivatecd
    if test -n "$RAVY_PRIVATE_HOME"
        builtin cd -- "$RAVY_PRIVATE_HOME"
    else
        echo "RAVY_PRIVATE_HOME is not configured" >&2
        return 1
    end
end

function chezp
    if set -q RAVY_PRIVATE_HOME; and test -n "$RAVY_PRIVATE_HOME"
        __ravy_chezmoi_run "$RAVY_PRIVATE_HOME" (__ravy_chezmoi_config_dir)/ravy-private.toml (__ravy_chezmoi_config_dir)/ravy-private-state.boltdb $argv
    else
        echo "RAVY_PRIVATE_HOME is not configured" >&2
        return 1
    end
end

function ravysource
    source "$HOME/.config/fish/config.fish"
end

function scd
    builtin cd -- "$HOME/.config/containers/systemd"
end

function scrall
    systemctl --user list-unit-files --state=generated --no-legend | awk '{print $1}' | while read -l unit
        test -n "$unit"
        and systemctl --user restart "$unit"
    end
end

function drc
    docker ps -f status=exited -q | while read -l container
        test -n "$container"
        and docker rm "$container"
    end
end

function dri
    docker images | awk '$1 == "<none>" { print $3 }' | while read -l image
        test -n "$image"
        and docker rmi "$image"
    end
end

function reset
    command reset
    and stty sane
    and tput reset
    and printf '\033c'
    and clear
    builtin cd -- "$PWD"
end
{{- else }}
# docker helpers
alias dpri='docker image prune'
alias dprs='docker system prune --all'
alias dli='docker image list'
alias dls='docker system info'
alias dry='docker run --rm -it -v /var/run/docker.sock:/var/run/docker.sock moncho/dry'

alias ravyc='ravyprivatecd'
alias ravyprivate='ravyprivatecd'
alias ravys='ravysource'

_ravy_chezmoi_config_dir() {
  printf '%s\n' "${XDG_CONFIG_HOME:-$HOME/.config}/chezmoi"
}

_ravy_chezmoi_seed_config() {
  config_path=$1
  [ -f "$config_path" ] && return 0

  config_dir="$(_ravy_chezmoi_config_dir)"
  for candidate in "$config_dir/chezmoi.toml" "$config_dir/ravy-public.toml"; do
    [ "$candidate" = "$config_path" ] && continue
    [ -f "$candidate" ] || continue
    mkdir -p "$(dirname "$config_path")"
    cp "$candidate" "$config_path"
    return 0
  done
}

_ravy_chezmoi_run() {
  source_dir=$1
  config_path=$2
  state_path=$3
  shift 3

  if [ "$#" -gt 0 ] && [ "$1" = "init" ]; then
    mkdir -p "$(dirname "$config_path")"
    shift
    command chezmoi -S "$source_dir" -c "$config_path" --persistent-state "$state_path" init -C "$config_path" "$@"
    [ -f "$config_path" ] || _ravy_chezmoi_seed_config "$config_path"
  else
    _ravy_chezmoi_seed_config "$config_path"
    command chezmoi -S "$source_dir" -c "$config_path" --persistent-state "$state_path" "$@"
  fi
}

d() {
  builtin cd ..
}

ravy() {
  builtin cd -- "$RAVY_HOME"
}

chez() {
  command chezmoi "$@"
}

ravycustom() {
  ravyprivatecd
}

ravyprivatecd() {
  if [ -n "${RAVY_PRIVATE_HOME:-}" ]; then
    builtin cd -- "$RAVY_PRIVATE_HOME"
  else
    echo "RAVY_PRIVATE_HOME is not configured" >&2
    return 1
  fi
}

chezp() {
  if [ -n "${RAVY_PRIVATE_HOME:-}" ]; then
    _ravy_chezmoi_run "$RAVY_PRIVATE_HOME" "$(_ravy_chezmoi_config_dir)/ravy-private.toml" "$(_ravy_chezmoi_config_dir)/ravy-private-state.boltdb" "$@"
  else
    echo "RAVY_PRIVATE_HOME is not configured" >&2
    return 1
  fi
}

ravysource() {
{{- if eq $shell "bash" }}
  . "$HOME/.bashrc"
{{- else }}
  . "$HOME/.zshrc"
{{- end }}
}

scd() {
  builtin cd -- "$HOME/.config/containers/systemd"
}

scrall() {
  systemctl --user list-unit-files --state=generated --no-legend | awk '{print $1}' | while IFS= read -r unit; do
    [ -n "$unit" ] && systemctl --user restart "$unit"
  done
}

drc() {
  docker ps -f status=exited -q | while IFS= read -r container; do
    [ -n "$container" ] && docker rm "$container"
  done
}

dri() {
  docker images | awk '$1 == "<none>" { print $3 }' | while IFS= read -r image; do
    [ -n "$image" ] && docker rmi "$image"
  done
}

reset() {
  command reset
  stty sane
  tput reset
  printf '\033c'
  clear
  builtin cd -- "$PWD"
}
{{- end }}
