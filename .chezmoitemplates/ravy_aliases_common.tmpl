{{- /* Common aliases shared across shells.
      Expects .shell to be "sh" or "fish".
      Keep this list restricted to commands that do NOT contain single quotes (for sh) or double quotes (for fish). */ -}}

{{- $shell := .shell | default "sh" -}}
{{- $aliases := list
  (dict "name" "c" "cmd" "cd")
  (dict "name" "ta" "cmd" "type -a")
  (dict "name" "df" "cmd" "command df -h")
  (dict "name" "g" "cmd" "command git")
  (dict "name" "t" "cmd" "command tmux")
  (dict "name" "hs" "cmd" "history")
  (dict "name" "tf" "cmd" "tail -f")
  (dict "name" "rd" "cmd" "rmdir")
  (dict "name" "rb" "cmd" "ruby")
  (dict "name" "v" "cmd" "nvim")
  (dict "name" "vi" "cmd" "nvim")
  (dict "name" "vim" "cmd" "nvim")
  (dict "name" "grep" "cmd" "grep -i")
  (dict "name" "pyserv" "cmd" "python3 -m http.server")

  (dict "name" "ag" "cmd" "rg -S")
  (dict "name" "rg" "cmd" "rg -S")
  (dict "name" "rgh" "cmd" "rg -S --hidden")

  (dict "name" "ts" "cmd" "tailscale")

  (dict "name" "ci" "cmd" "cursor-agent --model grok-code-fast-1")
  (dict "name" "cido" "cmd" "ci -p -f --output-format text --")

  (dict "name" "mu" "cmd" "mise upgrade")

  (dict "name" "pa" "cmd" "ps-color")
  (dict "name" "pc" "cmd" "env HIGH_CPU_MEM_ONLY=1 ps-color")
 -}}

{{- range $aliases }}
{{- if eq $shell "fish" }}
alias {{ .name }} "{{ .cmd }}"
{{- else }}
alias {{ .name }}='{{ .cmd }}'
{{- end }}
{{- end }}

{{- if eq $shell "fish" }}
if command -q brew
alias bi "brew install --force-bottle"
alias blr "brew list --installed-on-request"
alias bubu "brew update && brew outdated && brew upgrade && brew cleanup"
end

if command -q apt
alias au "sudo apt update && sudo apt full-upgrade && sudo apt autoclean"
alias auau "sudo apt update && sudo apt full-upgrade && sudo apt dist-upgrade && sudo apt autoclean && sudo apt autoremove"
end

if command -q pacman
alias pupu "sudo pacman -Syuu --noconfirm"
end

if command -q podman
alias pd "podman"
alias pdau "podman auto-update"
alias pdl "podman logs -f --tail 100"
end

if command -q systemctl
alias sc "systemctl --user"
alias sce "sc daemon-reload"
alias scs "sc status"
alias scr "sc restart"
alias scst "sc start"
alias scstop "sc stop"
end

if command -q docker
alias dp "dc pull"
alias dcl "dc logs -f --tail 100"
alias dcb "dc build"
alias dud "dc build && dc up -d --no-build"
alias dpdu "dc pull && dc up -d"
alias dudp "dpdu"
end
{{- else }}
if command -v brew >/dev/null 2>&1; then
  alias bi='brew install --force-bottle'
  alias blr='brew list --installed-on-request'
  alias bubu='brew update && brew outdated && brew upgrade && brew cleanup'
fi

if command -v apt >/dev/null 2>&1; then
  alias au='sudo apt update && sudo apt full-upgrade && sudo apt autoclean'
  alias auau='sudo apt update && sudo apt full-upgrade && sudo apt dist-upgrade && sudo apt autoclean && sudo apt autoremove'
fi

if command -v pacman >/dev/null 2>&1; then
  alias pupu='sudo pacman -Syuu --noconfirm'
fi

if command -v podman >/dev/null 2>&1; then
  alias pd='podman'
  alias pdau='podman auto-update'
  alias pdl='podman logs -f --tail 100'
fi

if command -v systemctl >/dev/null 2>&1; then
  alias sc='systemctl --user'
  alias sce='sc daemon-reload'
  alias scs='sc status'
  alias scr='sc restart'
  alias scst='sc start'
  alias scstop='sc stop'
fi

if command -v docker >/dev/null 2>&1; then
  alias dp='dc pull'
  alias dcl='dc logs -f --tail 100'
  alias dcb='dc build'
  alias dud='dc build && dc up -d --no-build'
  alias dpdu='dc pull && dc up -d'
  alias dudp='dpdu'
fi
{{- end }}
