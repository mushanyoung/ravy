# Ravy (chezmoi)
# shellcheck shell=bash

# Only for interactive shells
case "$-" in
  *i*) ;;
  *) return 0 ;;
esac

{{ template "ravy_sh_common.tmpl" . }}
{{ template "ravy_ls_eza_common.tmpl" (dict "shell" "sh") }}
{{ template "ravy_aliases_common.tmpl" (dict "shell" "sh") }}
{{ template "ravy_interactive_common.tmpl" (dict "shell" "bash") }}

# starship
if command -v starship >/dev/null 2>&1; then
  eval "$(starship init bash)"
fi

# mise
if command -v mise >/dev/null 2>&1; then
  eval "$(mise activate bash)"
fi

# atuin
if command -v atuin >/dev/null 2>&1; then
  eval "$(atuin init bash 2>/dev/null)"
fi

{{ template "ravy_custom_overrides_common.tmpl" (dict "shell" "bash") }}
