# Ravy (chezmoi)

# Only for interactive shells
[[ -o interactive ]] || return 0

{{ template "ravy_sh_common.tmpl" . }}
{{ template "ravy_ls_eza_common.tmpl" (dict "shell" "sh") }}
{{ template "ravy_aliases_common.tmpl" (dict "shell" "sh") }}
{{ template "ravy_interactive_common.tmpl" (dict "shell" "zsh") }}

# starship
if command -v starship >/dev/null 2>&1; then
  eval "$(starship init zsh)"
fi

# mise
if command -v mise >/dev/null 2>&1; then
  eval "$(mise activate zsh)"
fi

# atuin
if command -v atuin >/dev/null 2>&1; then
  eval "$(atuin init zsh 2>/dev/null)"
fi

