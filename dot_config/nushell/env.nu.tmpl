# Ravy (chezmoi) Nushell env

def path-is-file [path: string] {
    try {
        (($path | path expand) | path type) == "file"
    } catch {
        false
    }
}

def path-is-dir [path: string] {
    try {
        (($path | path expand) | path type) == "dir"
    } catch {
        false
    }
}

def command-output [cmd: string, ...args: string] {
    try {
        do { run-external $cmd ...$args } | complete
    } catch {
        { stdout: "", stderr: "", exit_code: 1 }
    }
}

def which-path [name: string] {
    let matches = (which -a $name | where type == external | get path)
    if ($matches | is-empty) {
        ""
    } else {
        $matches | first
    }
}

def --env path-prepend [path: string] {
    let trimmed = ($path | str trim)
    if ($trimmed | is-empty) {
        return
    }

    let expanded = ($trimmed | path expand)
    if not (path-is-dir $expanded) {
        return
    }

    let current = ($env.PATH? | default [])
    $env.PATH = ([$expanded] ++ ($current | where {|it| $it != $expanded }))
}

def --env path-append [path: string] {
    let trimmed = ($path | str trim)
    if ($trimmed | is-empty) {
        return
    }

    let expanded = ($trimmed | path expand)
    if not (path-is-dir $expanded) {
        return
    }

    let current = ($env.PATH? | default [])
    $env.PATH = (($current | where {|it| $it != $expanded }) ++ [$expanded])
}

def default-private-home [] {
    for candidate in [
        $"($env.HOME)/.local/share/ravy-private"
        $"($env.HOME)/.ravy-private"
        $"($env.RAVY_HOME? | default "")/custom"
    ] {
        let trimmed = ($candidate | str trim)
        if not ($trimmed | is-empty) and (path-is-dir $trimmed) {
            return $trimmed
        }
    }

    ""
}

if (($env.PATH? | default []) | describe) == "string" {
    $env.PATH = ($env.PATH | split row (char esep))
}

let chezmoi = (which-path "chezmoi")
if (($env.RAVY_HOME? | default "") | str trim | is-empty) and not ($chezmoi | str trim | is-empty) {
    let out = (command-output $chezmoi "source-path")
    let source_path = ($out.stdout | str trim)
    if ($out.exit_code == 0) and not ($source_path | is-empty) {
        $env.RAVY_HOME = $source_path
    }
}

if (($env.RAVY_HOME? | default "") | str trim | is-empty) {
    let default_source = $"($env.HOME)/.local/share/chezmoi"
    $env.RAVY_HOME = if (path-is-dir $default_source) {
        $default_source
    } else {
        $"($env.HOME)/.ravy"
    }
}
$env.RAVY_HOME = ($env.RAVY_HOME | path expand)

let private_home_was_set = not ((($env.RAVY_PRIVATE_HOME? | default "") | str trim) | is-empty)
if not $private_home_was_set {
    let candidate = (default-private-home)
    if not (($candidate | str trim) | is-empty) {
        $env.RAVY_PRIVATE_HOME = $candidate
    }
}

if not ((($env.RAVY_PRIVATE_HOME? | default "") | str trim) | is-empty) {
    if not (path-is-dir $env.RAVY_PRIVATE_HOME) {
        hide-env -i RAVY_PRIVATE_HOME
    } else {
        $env.RAVY_PRIVATE_HOME = ($env.RAVY_PRIVATE_HOME | path expand)
    }
}

$env.RAVY_CUSTOM = ($env.RAVY_PRIVATE_HOME? | default "")

if (($env.RAVY_HOST? | default "") | str trim | is-empty) {
    let host_out = (command-output "hostname" "-s")
    let host = ($host_out.stdout | str trim)
    $env.RAVY_HOST = if ($host_out.exit_code == 0) and not ($host | is-empty) {
        $host
    } else {
        "unknown"
    }
}
$env.RAVY_HOST = ($env.RAVY_HOST | str downcase)

if (($env.RAVY_OS? | default "") | str trim | is-empty) {
    let os_out = (command-output "uname" "-s")
    let os = ($os_out.stdout | str trim)
    $env.RAVY_OS = if ($os_out.exit_code == 0) and not ($os | is-empty) {
        $os
    } else {
        "unknown"
    }
}
$env.RAVY_OS = ($env.RAVY_OS | str downcase)

path-prepend $"($env.HOME)/bin"
path-prepend $"($env.HOME)/.local/bin"
path-prepend $"($env.HOME)/.bun/bin"
path-prepend $"($env.RAVY_HOME)/bin"
if not ((($env.RAVY_PRIVATE_HOME? | default "") | str trim) | is-empty) {
    path-append $"($env.RAVY_PRIVATE_HOME)/bin/common"
    path-append $"($env.RAVY_PRIVATE_HOME)/ops"
}

if (($env.RAVY_SKIP_BREW? | default "") | str trim | is-empty) {
    mut brewprefix = ""
    let brew = (which-path "brew")
    if not ($brew | str trim | is-empty) {
        let out = (command-output $brew "--prefix")
        let prefix = ($out.stdout | str trim)
        if ($out.exit_code == 0) and not ($prefix | is-empty) {
            $brewprefix = $prefix
        }
    }

    if ($brewprefix | is-empty) {
        for candidate in [
            "/opt/homebrew"
            "/usr/local"
            "/home/linuxbrew/.linuxbrew"
            $"($env.HOME)/.brew"
            $"($env.HOME)/.linuxbrew"
        ] {
            if (path-is-file $"($candidate)/bin/brew") {
                $brewprefix = $candidate
                break
            }
        }
    }

    if not ($brewprefix | is-empty) {
        $env.HOMEBREW_PREFIX = $brewprefix
        $env.HOMEBREW_CELLAR = $"($brewprefix)/Cellar"
        $env.HOMEBREW_REPOSITORY = $"($brewprefix)/Homebrew"
        $env.HOMEBREW_NO_ANALYTICS = "1"

        let share_man = $"($brewprefix)/share/man"
        if (path-is-dir $share_man) {
            let current = ($env.MANPATH? | default "")
            $env.MANPATH = if (($current | str trim) | is-empty) {
                $share_man
            } else {
                $"($share_man):($current)"
            }
        }

        let share_info = $"($brewprefix)/share/info"
        if (path-is-dir $share_info) {
            let current = ($env.INFOPATH? | default "")
            $env.INFOPATH = if (($current | str trim) | is-empty) {
                $share_info
            } else {
                $"($share_info):($current)"
            }
        }

        path-prepend $"($brewprefix)/opt/ruby/bin"
        path-prepend $"($brewprefix)/sbin"
        path-prepend $"($brewprefix)/bin"
    }
}

$env.LANG = "en_US.UTF-8"
$env.LANGUAGE = $env.LANG
$env.EDITOR = "nvim"
$env.GIT_EDITOR = "nvim"

if not ((($env.CURSOR_AGENT? | default "") | str trim) | is-empty) or not ((($env.CURSOR_TRACE_ID? | default "") | str trim) | is-empty) {
    $env.PAGER = "cat"
    $env.MANPAGER = "cat"
    $env.GIT_PAGER = "cat"
} else {
    $env.PAGER = "less"
    $env.MANPAGER = "less"
    $env.GIT_PAGER = "less"
}

$env.LESS = "FRXMi"
$env.LESS_TERMCAP_mb = (ansi red_bold)
$env.LESS_TERMCAP_md = (ansi { fg: "#5f87af" attr: b })
$env.LESS_TERMCAP_me = (ansi reset)
$env.LESS_TERMCAP_so = (ansi { fg: "#ffaf00" bg: "#303030" attr: r })
$env.LESS_TERMCAP_se = (ansi reset)
$env.LESS_TERMCAP_us = (ansi { fg: "#d7af5f" attr: u })
$env.LESS_TERMCAP_ue = (ansi reset)

$env.FZF_DEFAULT_OPTS = "--bind=ctrl-f:page-down,ctrl-b:page-up --layout=reverse --height=50% --border"
$env.FZF_DEFAULT_COMMAND = "fd"

$env.EZA_CONFIG_DIR = $"($env.HOME)/.config/eza"
$env.STARSHIP_CONFIG = $"($env.HOME)/.config/starship.toml"
$env._ZO_DATA_DIR = $"($env.HOME)/.local/share/zoxide"
$env.FISH_TITLE = ($env.FISH_TITLE? | default "")

if (($env.MAMBA_ROOT_PREFIX? | default "") | str trim | is-empty) {
    $env.MAMBA_ROOT_PREFIX = "/opt/conda"
}

if (($env.MAMBA_EXE? | default "") | str trim | is-empty) {
    let mamba = (which-path "mamba")
    if not ($mamba | str trim | is-empty) {
        $env.MAMBA_EXE = $mamba
    } else {
        for candidate in ["/opt/homebrew/bin/mamba" "/home/linuxbrew/.linuxbrew/bin/mamba"] {
            if (path-is-file $candidate) {
                $env.MAMBA_EXE = $candidate
                break
            }
        }
    }
}

if not ((($env.MAMBA_EXE? | default "") | str trim) | is-empty) {
    $env.MAMBA_NO_PROMPT = "1"
}
