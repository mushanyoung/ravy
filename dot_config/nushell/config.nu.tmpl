# Ravy (chezmoi) Nushell config

alias __core_cd = cd
alias __core_open = open

const __ravy_self_config = $nu.config-path

def path-is-file [path: string] {
    try {
        (($path | path expand) | path type) == "file"
    } catch {
        false
    }
}

def path-is-dir [path: string] {
    try {
        (($path | path expand) | path type) == "dir"
    } catch {
        false
    }
}

def command-output [cmd: string, ...args: string] {
    try {
        do { run-external $cmd ...$args } | complete
    } catch {
        { stdout: "", stderr: "", exit_code: 1 }
    }
}

def which-path [name: string] {
    let matches = (which -a $name | where type == external | get path)
    if ($matches | is-empty) {
        ""
    } else {
        $matches | first
    }
}

def escape-args [items: list<string>] {
    $items | each {|item| $item | to nuon } | str join " "
}

def --env ensure-keybinding [binding: record] {
    let bindings = ($env.config | get -o keybindings | default [])
    let filtered = ($bindings | where {|row| (($row | get -o name) | default "") != $binding.name })
    $env.config = ($env.config | upsert keybindings ($filtered | append $binding))
}

def --env ensure-hook [field: cell-path, marker: string, hook: record] {
    let existing = ($env.config | get -o $field | default [])
    let filtered = ($existing | where {|row| (($row | get -o $marker) | default false) != true })
    $env.config = ($env.config | upsert $field ($filtered | append $hook))
}

def expand-secrets-home [value: string] {
    let home = ($env.HOME | path expand)
    if $value == "~" {
        $home
    } else if ($value | str starts-with "~/") {
        $"($home)($value | str substring 1..)"
    } else {
        $value
    }
}

def --env load-secrets-tsv [file: string] {
    let path = ($file | path expand)
    if not (path-is-file $path) {
        return
    }

    for line in (open $path | lines) {
        let trimmed = ($line | str trim)
        if ($trimmed | is-empty) or ($trimmed | str starts-with "#") {
            continue
        }

        let entry = ($trimmed | split row (char tab))
        if ($entry | length) < 2 {
            continue
        }

        let key = (($entry | first) | str trim -c " \t\r")
        let value = (
            $entry
            | skip 1
            | str join (char tab)
            | str trim -l -c " \t"
            | str trim -r -c "\r"
            | expand-secrets-home
        )
        if ($key | is-empty) or ($key | str starts-with "#") {
            continue
        }
        load-env { ($key): $value }
    }
}

def ravy-secrets-tsv [] {
    let config_home = ($env.XDG_CONFIG_HOME? | default $"($env.HOME)/.config")
    $"($config_home)/ravy/secrets.tsv"
}

def ravy-title-or-pwd [] {
    if not ((($env.FISH_TITLE? | default "") | str trim) | is-empty) {
        $env.FISH_TITLE
    } else {
        let home = ($env.HOME | path expand)
        if $env.PWD == $home {
            "~"
        } else if ($env.PWD | str starts-with $"($home)/") {
            $"~($env.PWD | str substring ($home | str length)..)"
        } else {
            $env.PWD
        }
    }
}

def ravy-set-title [prefix?: string] {
    let title = if ($prefix | default "" | str trim | is-empty) {
        (ravy-title-or-pwd)
    } else {
        $"($prefix) (ravy-title-or-pwd)"
    }

    print -n $"\u{1b}]0;($title)\u{7}"
}

def --env ravy-dirprev [] {
    $env.__RAVY_DIRPREV = ($env.__RAVY_DIRPREV? | default [])
    $env.__RAVY_DIRNEXT = ($env.__RAVY_DIRNEXT? | default [])
    $env.__RAVY_CD_DIRECTION = ($env.__RAVY_CD_DIRECTION? | default "prev")
}

def ravy-resolve-cd-target [target?: string] {
    let raw_target = ($target | default $env.HOME)
    if $raw_target == "-" {
        return "-"
    }

    let trimmed = ($raw_target | str trim)
    if ($trimmed | is-empty) {
        return $env.HOME
    }

    mut candidate = $trimmed
    while not ($candidate | is-empty) and not (path-is-dir $candidate) {
        let parent = ($candidate | path dirname)
        if ($parent == $candidate) or ($parent == ".") {
            break
        }
        $candidate = $parent
    }

    if (path-is-dir $candidate) {
        $candidate
    } else {
        $trimmed
    }
}

def --env ravy-cd-push [previous: string] {
    ravy-dirprev
    let updated = (($env.__RAVY_DIRPREV | default []) | append $previous)
    let len = ($updated | length)
    $env.__RAVY_DIRPREV = if $len > 25 {
        $updated | skip ($len - 25)
    } else {
        $updated
    }
    $env.__RAVY_DIRNEXT = []
    $env.__RAVY_CD_DIRECTION = "prev"
}

def --env ravy-cd-prev [] {
    ravy-dirprev
    if (($env.__RAVY_DIRPREV | length) == 0) {
        return
    }

    let previous = $env.PWD
    let target = ($env.__RAVY_DIRPREV | last)
    let prev_len = ($env.__RAVY_DIRPREV | length)
    $env.__RAVY_DIRPREV = if $prev_len > 1 {
        $env.__RAVY_DIRPREV | take ($prev_len - 1)
    } else {
        []
    }
    __core_cd $target
    if $env.PWD != $previous {
        $env.__RAVY_DIRNEXT = ([$previous] ++ ($env.__RAVY_DIRNEXT | default []))
        $env.__RAVY_CD_DIRECTION = "next"
    }
}

def --env ravy-cd-next [] {
    ravy-dirprev
    if (($env.__RAVY_DIRNEXT | length) == 0) {
        return
    }

    let previous = $env.PWD
    let target = ($env.__RAVY_DIRNEXT | first)
    $env.__RAVY_DIRNEXT = ($env.__RAVY_DIRNEXT | skip 1)
    __core_cd $target
    if $env.PWD != $previous {
        let updated = (($env.__RAVY_DIRPREV | default []) | append $previous)
        let len = ($updated | length)
        $env.__RAVY_DIRPREV = if $len > 25 {
            $updated | skip ($len - 25)
        } else {
            $updated
        }
        $env.__RAVY_CD_DIRECTION = "prev"
    }
}

def --env cd [target?: string] {
    ravy-dirprev

    if ($target | default "") == "-" {
        if ($env.__RAVY_CD_DIRECTION? | default "prev") == "next" {
            ravy-cd-next
        } else {
            ravy-cd-prev
        }
        return
    }

    let previous = $env.PWD
    let resolved = (ravy-resolve-cd-target $target)
    __core_cd $resolved
    if $env.PWD != $previous {
        ravy-cd-push $previous
    }
}

def --env d [] {
    cd ..
}

def --env ravy [] {
    cd $env.RAVY_HOME
}

def ravy-chezmoi-config-dir [] {
    let config_home = ($env.XDG_CONFIG_HOME? | default $"($env.HOME)/.config")
    $"($config_home)/chezmoi"
}

def ravy-chezmoi-seed-config [config_path: string] {
    let expanded = ($config_path | path expand)
    if (path-is-file $expanded) {
        return
    }

    let config_dir = (ravy-chezmoi-config-dir)
    for candidate in [
        $"($config_dir)/chezmoi.toml"
        $"($config_dir)/ravy-public.toml"
    ] {
        if ($candidate == $expanded) or not (path-is-file $candidate) {
            continue
        }

        do { run-external "mkdir" "-p" ($expanded | path dirname) } | complete | ignore
        do { run-external "cp" $candidate $expanded } | complete | ignore
        return
    }
}

def ravy-chezmoi-private-home [] {
    let private_home = (($env.RAVY_PRIVATE_HOME? | default "") | str trim)
    if ($private_home | is-empty) {
        error make { msg: "RAVY_PRIVATE_HOME is not configured" }
    }

    $private_home
}

def ravy-chezmoi-flag-consumes-next [arg: string] {
    let long_value_flags = [
        "--age-recipient"
        "--age-recipient-file"
        "--cache"
        "--color"
        "--config"
        "--config-format"
        "--destination"
        "--exclude"
        "--include"
        "--mode"
        "--output"
        "--override-data"
        "--override-data-file"
        "--pager"
        "--path-style"
        "--persistent-state"
        "--progress"
        "--refresh-externals"
        "--source"
        "--working-tree"
    ]
    let short_value_flags = ["-c" "-D" "-i" "-o" "-p" "-R" "-S" "-W" "-x"]

    if not ($arg | str starts-with "-") {
        return false
    }

    if ($arg | str starts-with "--") {
        if ($arg | str contains "=") {
            return false
        }

        return ($long_value_flags | any {|flag| $flag == $arg })
    }

    if ($short_value_flags | any {|flag| $flag == $arg }) {
        return true
    }

    false
}

def ravy-chezmoi-find-subcommand [args: list<string>] {
    mut index = 0
    while $index < ($args | length) {
        let arg = ($args | get $index)
        if $arg == "--" {
            return null
        }

        if ($arg | str starts-with "-") {
            $index = if (ravy-chezmoi-flag-consumes-next $arg) {
                $index + 2
            } else {
                $index + 1
            }
            continue
        }

        return {
            index: $index
            name: $arg
        }
    }

    null
}

def ravy-chezmoi-should-run-both [args: list<string>] {
    let subcommand = (ravy-chezmoi-find-subcommand $args)
    if $subcommand == null {
        return false
    }

    if not (($subcommand.name | default "") in ["apply" "diff" "status"]) {
        return false
    }

    mut index = ($subcommand.index + 1)
    while $index < ($args | length) {
        let arg = ($args | get $index)
        if $arg == "--" {
            $index = ($index + 1)
            return $index >= ($args | length)
        }

        if ($arg | str starts-with "-") {
            $index = if (ravy-chezmoi-flag-consumes-next $arg) {
                $index + 2
            } else {
                $index + 1
            }
            continue
        }

        return false
    }

    true
}

def --env ravy-chezmoi-run-private [...args: string] {
    let private_home = (ravy-chezmoi-private-home)
    let config_dir = (ravy-chezmoi-config-dir)
    let config_path = $"($config_dir)/ravy-private.toml"
    let state_path = $"($config_dir)/ravy-private-state.boltdb"

    if (($args | length) > 0) and (($args | first) == "init") {
        do { run-external "mkdir" "-p" ($config_path | path dirname) } | complete | ignore
        run-external "chezmoi" "-S" $private_home "-c" $config_path "--persistent-state" $state_path "init" "-C" $config_path ...($args | skip 1)
        if not (path-is-file $config_path) {
            ravy-chezmoi-seed-config $config_path
        }
    } else {
        ravy-chezmoi-seed-config $config_path
        run-external "chezmoi" "-S" $private_home "-c" $config_path "--persistent-state" $state_path ...$args
    }
}

def --env chez [...args: string] {
    if (($args | length) > 0) and (($args | first) == "private") {
        ravy-chezmoi-run-private ...($args | skip 1)
        return
    }

    if (ravy-chezmoi-should-run-both $args) {
        run-external "chezmoi" ...$args
        if (($env.LAST_EXIT_CODE? | default 0) != 0) {
            return
        }

        let private_home = (($env.RAVY_PRIVATE_HOME? | default "") | str trim)
        if not ($private_home | is-empty) {
            ravy-chezmoi-run-private ...$args
        }
        return
    }

    run-external "chezmoi" ...$args
}

def --env ravyprivatecd [] {
    let private_home = (($env.RAVY_PRIVATE_HOME? | default "") | str trim)
    if ($private_home | is-empty) {
        error make { msg: "RAVY_PRIVATE_HOME is not configured" }
    }

    cd $private_home
}

def --env ravycustom [] {
    ravyprivatecd
}

def --env chezp [...args: string] {
    chez private ...$args
}

def --env ravysource [] {
    print $"reload config from ($__ravy_self_config) in a new Nushell session"
}

def --env imv [...sources: string] {
    for src in $sources {
        let expanded = ($src | path expand)
        if not (($expanded | path exists)) {
            print $"($src) does not exist"
            continue
        }

        let renamed = (input $"rename ($expanded) to> ")
        let target = ($renamed | str trim)
        if ($target | is-empty) or ($target == $expanded) {
            continue
        }

        do { run-external "mkdir" "-p" (($target | path expand) | path dirname) } | complete | ignore
        do { run-external "mv" $expanded ($target | path expand) } | complete | ignore
    }
}

def --wrapped ls [...args: string] {
    let eza = (which-path "eza")
    if ($eza | str trim | is-empty) {
        run-external "ls" ...$args
    } else {
        run-external $eza "--icons" "--group-directories-first" "--git" "--color=auto" ...$args
    }
}

def --wrapped sysopen [...paths: string] {
    let remote_open = (which-path "open-remote")
    let mac_open = (which-path "open")
    let xdg_open = (which-path "xdg-open")

    for path in $paths {
        if not ((($env.SSH_CONNECTION? | default "") | str trim) | is-empty) and not ($remote_open | is-empty) {
            do { run-external $remote_open $path } | complete | ignore
        } else if not ($mac_open | is-empty) {
            do { run-external $mac_open $path } | complete | ignore
        } else if not ($xdg_open | is-empty) {
            do { run-external $xdg_open $path } | complete | ignore
        }
    }
}

def ravy-fzf-run [items: list<string>, prompt: string, ...extra_args: string] {
    let fzf = (which-path "fzf")
    let candidates = ($items | where {|line| not (($line | str trim) | is-empty) })
    if ($fzf | is-empty) or ($candidates | is-empty) {
        return ""
    }

    let args = ([
        "--height=45%"
        "--bind" "ctrl-f:page-down,ctrl-b:page-up"
        "--reverse"
        "--prompt" $"($prompt)> "
    ] | append $extra_args)
    let out = (
        $candidates
        | str join (char nl)
        | do { run-external $fzf ...$args }
        | complete
    )

    let lines = ($out.stdout | lines)
    if ($lines | is-empty) {
        ""
    } else {
        ($lines | first | str trim)
    }
}

def ravy-fzf-file-preview [] {
    let bat = (which-path "bat")
    if ($bat | is-empty) {
        "cat {}"
    } else {
        "bat --color=always --style=numbers --line-range=:500 -- {}"
    }
}

def ravy-open-editor [path: string] {
    if (($path | str trim) | is-empty) {
        return
    }

    let editor = ($env.EDITOR? | default "nvim")
    run-external $editor "--" $path
}

def ravy-fzf-history [] {
    let items = (history | get command | reverse | uniq)
    let current = (commandline | str trim)
    let selected = (ravy-fzf-run $items "History" "-q" $current "--tiebreak" "index")
    if not (($selected | str trim) | is-empty) {
        commandline edit $selected
    }
}

def ravy-fzf-files [] {
    let fd = (which-path "fd")
    if ($fd | is-empty) {
        return
    }

    let items = ((command-output $fd "-t" "f").stdout | lines)
    let selected = (ravy-fzf-run $items "File" "--preview" (ravy-fzf-file-preview) "--preview-window" "right:wrap")
    ravy-open-editor $selected
}

def ravy-fzf-files-hidden [] {
    let fd = (which-path "fd")
    if ($fd | is-empty) {
        return
    }

    let items = ((command-output $fd "-H" "-t" "f").stdout | lines)
    let selected = (ravy-fzf-run $items ".File" "--preview" (ravy-fzf-file-preview) "--preview-window" "right:wrap")
    ravy-open-editor $selected
}

def ravy-fzf-dirs [] {
    let fd = (which-path "fd")
    if ($fd | is-empty) {
        return
    }

    let items = ((command-output $fd "-t" "d").stdout | lines)
    let selected = (ravy-fzf-run $items "Dir")
    if not (($selected | str trim) | is-empty) {
        cd $selected
    }
}

def ravy-fzf-dirs-hidden [] {
    let fd = (which-path "fd")
    if ($fd | is-empty) {
        return
    }

    let items = ((command-output $fd "-H" "-t" "d").stdout | lines)
    let selected = (ravy-fzf-run $items ".Dir")
    if not (($selected | str trim) | is-empty) {
        cd $selected
    }
}

def ravy-fzf-nvim [] {
    let nvim = (which-path "nvim")
    if ($nvim | is-empty) {
        return
    }

    let items = (
        command-output $nvim "--headless" "+lua for _,f in ipairs(vim.v.oldfiles) do io.write(f .. \"\\n\") end" "+qa"
    ).stdout | lines
    let selected = (ravy-fzf-run $items "File(nvim)" "--preview" (ravy-fzf-file-preview) "--preview-window" "right:wrap")
    ravy-open-editor $selected
}

def ravy-fzf-rg [] {
    let rg = (which-path "rg")
    if ($rg | is-empty) {
        return
    }

    let keyword = (commandline | str trim)
    if ($keyword | is-empty) {
        return
    }

    let items = ((command-output $rg "-il" "--" $keyword).stdout | lines)
    let selected = (ravy-fzf-run $items $"Search /($keyword)/" "--preview" (ravy-fzf-file-preview) "--preview-window" "right:wrap")
    ravy-open-editor $selected
}

def ravy-type-current [] {
    let current = (commandline | str trim)
    if ($current | is-empty) {
        return
    }

    let cmd = ($current | split row " " | first)
    if ($cmd | str trim | is-empty) {
        return
    }

    do { run-external "which" "-a" $cmd } | complete | get stdout | print
}

def ravy-history-token [direction: string] {
    let query = (commandline | str trim)
    let matches = if ($query | is-empty) {
        history | get command | reverse
    } else {
        history | get command | reverse | where {|cmd| $cmd | str contains $query }
    }

    if ($matches | is-empty) {
        return
    }

    let replacement = if $direction == "forward" {
        $matches | reverse | first
    } else {
        $matches | first
    }

    commandline edit $replacement
}

def ravy-prepend-last-history-line [] {
    let items = (history | get command)
    if ($items | is-empty) {
        return
    }

    commandline edit --append ($items | last)
}

def ravy-fg [] {
    let jobs = (job list)
    if ($jobs | is-empty) {
        return
    }

    let fzf = (which-path "fzf")
    if ($fzf | is-empty) {
        job unfreeze
        return
    }

    let picked = (
        $jobs
        | each {|row| $"($row.id)\t($row.command? | default ($row.type? | default "job"))" }
        | str join (char nl)
        | do { run-external $fzf "-0" "-1" "--tac" }
        | complete
        | get stdout
        | str trim
    )

    if ($picked | is-empty) {
        return
    }

    let id = ($picked | split row (char tab) | first | into int)
    job unfreeze $id
}

def --env scd [] {
    cd $"($env.HOME)/.config/containers/systemd"
}

def scrall [] {
    let units = (
        command-output "systemctl" "--user" "list-unit-files" "--state=generated" "--no-legend"
    ).stdout | lines | each {|line| $line | split row " " | first } | where {|unit| not (($unit | str trim) | is-empty) }

    for unit in $units {
        do { run-external "systemctl" "--user" "restart" $unit } | complete | ignore
    }
}

def drc [] {
    let containers = ((command-output "docker" "ps" "-f" "status=exited" "-q").stdout | lines | where {|id| not (($id | str trim) | is-empty) })
    for container in $containers {
        do { run-external "docker" "rm" $container } | complete | ignore
    }
}

def dri [] {
    let images = (
        command-output "docker" "images"
    ).stdout | lines | skip 1 | each {|line|
        let cols = ($line | split row " " | where {|col| not (($col | str trim) | is-empty) })
        if (($cols | length) >= 3) and (($cols | first) == "<none>") {
            $cols | get 2
        } else {
            null
        }
    } | compact

    for image in $images {
        do { run-external "docker" "rmi" $image } | complete | ignore
    }
}

def --env reset [] {
    do { run-external "reset" } | complete | ignore
    do { run-external "stty" "sane" } | complete | ignore
    do { run-external "tput" "reset" } | complete | ignore
    print -n "\u{1b}c"
    do { run-external "clear" } | complete | ignore
    cd $env.PWD
}

def parse-vars [] {
    $in | from csv --noheaders --no-infer | rename op name value
}

def --env update-env [] {
    for var in $in {
        if $var.op == "set" {
            if (($var.name | str upcase) == "PATH") {
                $env.PATH = ($var.value | split row (char esep))
            } else {
                load-env { ($var.name): $var.value }
            }
        } else if ($var.op == "hide") and ($var.name in $env) {
            hide-env $var.name
        }
    }
}

def --env ravy-mise-hook [] {
    let mise = (which-path "mise")
    if ($mise | is-empty) {
        return
    }

    $env.MISE_SHELL = "nu"
    $env.__RAVY_MISE_INIT = "1"

    let hook_out = (command-output $mise "hook-env" "-s" "nu")
    if ($hook_out.exit_code == 0) and not (($hook_out.stdout | str trim) | is-empty) {
        $hook_out.stdout | parse-vars | update-env
    }
}

def --env ravy-atuin-pre-execution [] {
    let atuin = (which-path "atuin")
    if ($atuin | is-empty) {
        return
    }

    let cmd = (commandline | str trim)
    if ($cmd | is-empty) {
        return
    }

    let out = (command-output $atuin "history" "start" "--" $cmd)
    let history_id = ($out.stdout | str trim)
    if ($out.exit_code == 0) and not ($history_id | is-empty) {
        $env.ATUIN_HISTORY_ID = $history_id
    }
}

def --env ravy-atuin-pre-prompt [] {
    let atuin = (which-path "atuin")
    if ($atuin | is-empty) or ((($env.ATUIN_HISTORY_ID? | default "") | str trim) | is-empty) {
        return
    }

    let exit_code = ($env.LAST_EXIT_CODE? | default 0 | into string)
    do { run-external $atuin "history" "end" $"--exit=($exit_code)" "--" $env.ATUIN_HISTORY_ID } | complete | ignore
    hide-env -i ATUIN_HISTORY_ID
}

def ravy-atuin-search [] {
    let atuin = (which-path "atuin")
    if ($atuin | is-empty) {
        return
    }

    let out = (command-output $atuin "search" "--interactive")
    let result = ($out.stdout | str trim)
    if ($result | str starts-with "__atuin_accept__:") {
        commandline edit --accept ($result | str replace "__atuin_accept__:" "")
    } else if not ($result | is-empty) {
        commandline edit $result
    }
}

def ravy-starship-prompt [--right] {
    let starship = (which-path "starship")
    if ($starship | is-empty) {
        return ""
    }

    let last_exit = ($env.LAST_EXIT_CODE? | default 0 | into string)
    let cmd_duration = if (($env.CMD_DURATION_MS? | default "0823") == "0823") {
        "0"
    } else {
        $env.CMD_DURATION_MS | into string
    }

    let job_args = if (which "job list" | where type == built-in | is-not-empty) {
        ["--jobs" ((job list | length) | into string)]
    } else {
        []
    }

    let args = if $right {
        [
            "prompt"
            "--right"
            "--cmd-duration" $cmd_duration
            $"--status=($last_exit)"
            "--terminal-width" ((term size).columns | into string)
        ] ++ $job_args
    } else {
        [
            "prompt"
            "--cmd-duration" $cmd_duration
            $"--status=($last_exit)"
            "--terminal-width" ((term size).columns | into string)
        ] ++ $job_args
    }

    (command-output $starship ...$args).stdout
}

$env.config = ($env.config? | default {})
$env.config = ($env.config
    | upsert edit_mode "emacs"
    | upsert history.file_format "plaintext"
    | upsert history.max_size 100000
    | upsert history.sync_on_enter true
    | upsert show_banner false
    | upsert keybindings ($env.config | get -o keybindings | default [])
    | upsert hooks ($env.config | get -o hooks | default {})
)

ensure-hook hooks.pre_prompt "__ravy_title_hook" {
    __ravy_title_hook: true
    code: {||
        ravy-set-title
    }
}

ensure-hook hooks.pre_execution "__ravy_title_exec_hook" {
    __ravy_title_exec_hook: true
    code: {||
        let line = (commandline | str trim)
        let cmd = if ($line | is-empty) { "" } else { $line | split row " " | first }
        if ($cmd | is-empty) or ($cmd == "nu") {
            ravy-set-title
        } else {
            ravy-set-title $cmd
        }
    }
}

if not ((which-path "mise") | is-empty) {
    ravy-mise-hook
    ensure-hook hooks.pre_prompt "__ravy_mise_hook" {
        __ravy_mise_hook: true
        code: {||
            ravy-mise-hook
        }
    }
    ensure-hook hooks.env_change.PWD "__ravy_mise_pwd_hook" {
        __ravy_mise_pwd_hook: true
        code: {|_, _|
            ravy-mise-hook
        }
    }
}

if not ((which-path "zoxide") | is-empty) {
    ensure-hook hooks.env_change.PWD "__ravy_zoxide_pwd_hook" {
        __ravy_zoxide_pwd_hook: true
        code: {|_, dir|
            do { run-external "zoxide" "add" "--" $dir } | complete | ignore
        }
    }

    def --env --wrapped z [...rest: string] {
        let path = match $rest {
            [] => { "~" }
            [ "-" ] => { "-" }
            [ $arg ] if (path-is-dir $arg) => { $arg }
            _ => {
                command-output "zoxide" "query" "--exclude" $env.PWD "--" ...$rest | get stdout | str trim -r -c "\n"
            }
        }
        cd $path
    }

    def --env --wrapped zi [...rest: string] {
        let target = (command-output "zoxide" "query" "--interactive" "--" ...$rest | get stdout | str trim -r -c "\n")
        if not ($target | is-empty) {
            cd $target
        }
    }
}

if not ((which-path "atuin") | is-empty) {
    if (($env.ATUIN_SESSION? | default "") | str trim | is-empty) {
        $env.ATUIN_SESSION = (random uuid | str replace -a "-" "")
    }
    $env.ATUIN_SHLVL = ($env.SHLVL? | default "")
    hide-env -i ATUIN_HISTORY_ID

    ensure-hook hooks.pre_execution "__ravy_atuin_pre_execution" {
        __ravy_atuin_pre_execution: true
        code: {||
            ravy-atuin-pre-execution
        }
    }
    ensure-hook hooks.pre_prompt "__ravy_atuin_pre_prompt" {
        __ravy_atuin_pre_prompt: true
        code: {||
            ravy-atuin-pre-prompt
        }
    }
}

if not ((which-path "starship") | is-empty) {
    $env.STARSHIP_SHELL = "nu"
    $env.STARSHIP_SESSION_KEY = (random chars -l 16)
    $env.PROMPT_MULTILINE_INDICATOR = (command-output "starship" "prompt" "--continuation" | get stdout)
    $env.PROMPT_INDICATOR = ""
    $env.PROMPT_COMMAND = {||
        ravy-starship-prompt
    }
    $env.PROMPT_COMMAND_RIGHT = {||
        ravy-starship-prompt --right
    }
    $env.config = ($env.config | upsert render_right_prompt_on_last_line true)
}

